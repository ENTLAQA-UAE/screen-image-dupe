# ==============================================================================
# Qudurat — Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env, .env.local, or any file with real secrets.
# ==============================================================================

# ---------------------------------------------------------------------------
# Supabase (current Vite build)
# ---------------------------------------------------------------------------
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# ---------------------------------------------------------------------------
# Supabase (Next.js migration — Phase 1 Week 2+)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your_project_id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---------------------------------------------------------------------------
# AI Providers (platform default — tenants can override in settings)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Email Providers (platform default — tenants can override in settings)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=hello@qudurat.com
EMAIL_FROM_NAME=Qudurat

# ---------------------------------------------------------------------------
# Payments (Phase 1 Week 6)
# ---------------------------------------------------------------------------
# Choose one — Lemon Squeezy (recommended for MENA VAT) or Stripe
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=

STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# ---------------------------------------------------------------------------
# Observability (Phase 3 Week 14)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---------------------------------------------------------------------------
# Tenant / Domain Management (Phase 2 Week 9)
# ---------------------------------------------------------------------------
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# ---------------------------------------------------------------------------
# Rate Limiting (Phase 1 Week 2+)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# App Configuration
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://qudurat.com
NEXT_PUBLIC_APP_NAME=Qudurat
NODE_ENV=development
