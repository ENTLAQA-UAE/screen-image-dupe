# ==============================================================================
# Qudurat Next.js — Environment Variables
# ==============================================================================
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ==============================================================================

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your_project_id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---------------------------------------------------------------------------
# App Configuration
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Qudurat

# ---------------------------------------------------------------------------
# AI Providers (platform default — tenants can override in settings)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Email Providers (platform default — tenants can override in settings)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=hello@qudurat.com
EMAIL_FROM_NAME=Qudurat

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Observability (Phase 3 Week 14)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---------------------------------------------------------------------------
# Payments (Phase 1 Week 6)
# ---------------------------------------------------------------------------
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=

# ---------------------------------------------------------------------------
# Tenant / Domain Management (Phase 2 Week 9)
# ---------------------------------------------------------------------------
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
